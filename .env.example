# ============================================================================
# Mosi configuration
# Copy to .env and fill in the required values:  cp .env.example .env
# ============================================================================

# --- Required -----------------------------------------------------------
# Postgres password used by docker-compose for the db service AND embedded
# in DATABASE_URL below. Generate one: openssl rand -hex 16
# (Boot is refused while DATABASE_URL still contains the literal "change-me".)
DB_PASSWORD=

# Connection string the app uses. With docker compose, the host is `db`.
DATABASE_URL=postgres://app:${DB_PASSWORD}@db:5432/mosi

# Session-cookie signing/derivation secret. Generate: openssl rand -hex 32
# Required; boot is refused if unset or shorter than 32 characters.
SESSION_SECRET=

# Public origin of the deployment (required by adapter-node for CSRF/redirects).
# In production this MUST be an https:// URL or boot is refused.
ORIGIN=https://events.example.com

NODE_ENV=production

# Set true when running behind the (recommended) external reverse proxy.
TRUST_PROXY=true

# --- Optional: Web Push (admin phone notifications) ----------------------
# Generate once:  npx web-push generate-vapid-keys
# Leave blank to disable push (the UI hides the option).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Optional: email (guest magic edit links) ----------------------------
# Leave SMTP_HOST unset to keep email OFF (the default; nothing requires it).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Mosi <no-reply@example.com>"

# --- Optional: admin bootstrap & 2FA policy ------------------------------
# Auto-create the first owner account on first run (skips the /admin/setup
# wizard's create step). Leave ADMIN_PASSWORD blank to use the wizard instead.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Require TOTP two-factor for admins. Default (unset/true) forces enrollment.
# Set to false to make 2FA optional: password-only login, handy for testing.
# Accounts that DID enable 2FA are always still challenged for it.
REQUIRE_TOTP=true

# --- Recommended: encrypt email addresses at rest ------------------------
# When set, guest/admin emails are stored AES-256-GCM encrypted (a keyed hash
# is kept alongside so the "resend my link" lookup still works). Generate with
# `openssl rand -hex 32`. KEEP THIS SAFE AND STABLE. Losing it makes existing
# encrypted emails unrecoverable. If you set it on an instance that already has
# data, run `pnpm db:encrypt-emails` once to encrypt the existing rows.
# When set, it must be 64 hex chars (32 bytes) or a ≥32-char passphrase.
ENCRYPTION_KEY=

# --- Optional ------------------------------------------------------------
# One-time token required to access /admin/setup on a fresh deploy.
BOOTSTRAP_TOKEN=

# Guest RSVP submission rate limit per IP (e.g. 30/min, 100/hour).
RATE_LIMIT_RSVP=30/min

# Login + 2FA attempt rate limit per IP.
RATE_LIMIT_LOGIN=10/min

# Allow webhook notifiers on private/LAN addresses (ntfy on your LAN, etc.).
# Blocked by default to prevent SSRF.
ALLOW_PRIVATE_WEBHOOKS=false
