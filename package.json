{
	"name": "mosi",
	"version": "1.0.2",
	"private": true,
	"description": "Self-hostable party & event invitation system: SvelteKit + Tailwind + PostgreSQL, installable PWA with Web Push.",
	"license": "AGPL-3.0-or-later",
	"author": "catagris",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/catagris/mosi.git"
	},
	"homepage": "https://github.com/catagris/mosi#readme",
	"bugs": "https://github.com/catagris/mosi/issues",
	"keywords": [
		"sveltekit",
		"potluck",
		"rsvp",
		"events",
		"self-hosted",
		"pwa",
		"web-push",
		"postgresql",
		"docker"
	],
	"type": "module",
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node scripts/start.mjs",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint . --quiet",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:unit": "vitest run",
		"test:e2e": "playwright test",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "node scripts/migrate.mjs",
		"db:seed": "tsx scripts/seed.ts",
		"db:encrypt-emails": "node scripts/encrypt-existing.mjs"
	},
	"dependencies": {
		"@node-rs/argon2": "^2.0.2",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.38.3",
		"marked": "^15.0.4",
		"nodemailer": "^6.9.16",
		"otpauth": "^9.3.6",
		"pg": "^8.13.1",
		"qrcode": "^1.5.4",
		"sanitize-html": "^2.14.0",
		"web-push": "^3.6.7",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.49.1",
		"@sveltejs/adapter-node": "^5.2.11",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@types/node": "^25.9.3",
		"@types/nodemailer": "^6.4.17",
		"@types/pg": "^8.11.10",
		"@types/qrcode": "^1.5.5",
		"@types/sanitize-html": "^2.13.0",
		"@types/web-push": "^3.6.4",
		"autoprefixer": "^10.4.20",
		"drizzle-kit": "^0.30.1",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.14.0",
		"postcss": "^8.4.49",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.2",
		"svelte": "^5.19.0",
		"svelte-check": "^4.1.4",
		"tailwindcss": "^3.4.17",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.19.1",
		"vite": "^6.0.7",
		"vitest": "^3.0.2"
	}
}
